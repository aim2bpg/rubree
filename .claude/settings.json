{
  "mcpServers": {
    "playwright": {
      "command": "node_modules/.bin/playwright-mcp",
      "args": ["--headless"]
    }
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(socat *)",
      "Read(./config/master.key)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.ssh/**)",
      "Bash(cat ~/.ssh/id_*)"
    ],
    "ask": [
      "Bash(sudo *)",
      "Bash(ssh *)",
      "Bash(gem push *)",
      "Bash(npm install *)",
      "Bash(npm publish*)",
      "Bash(yarn publish*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh issue create*)",
      "Bash(gh release*)",
      "Bash(gh workflow run*)",
      "Write(./.claude/settings.json)",
      "Edit(./.claude/settings.json)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // empty' | { read -r cmd; if echo \"$cmd\" | grep -qE 'git[[:space:]]+push' && echo \"$cmd\" | grep -qE '(--force|--force-with-lease|-f\\b)' && echo \"$cmd\" | grep -qE '\\b(main|master)\\b'; then printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Force-pushing to main or master is blocked by project policy\"}}\\n'; fi; }"
          }
        ]
      }
    ]
  }
}
